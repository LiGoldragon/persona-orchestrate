#!/usr/bin/env bash
set -euo pipefail

mind="${MIND_BIN:?MIND_BIN must point at the mind binary}"
workspace="$(mktemp -d)"
socket="$workspace/mind.sock"
store="$workspace/mind.redb"

"$mind" daemon --socket "$socket" --store "$store" >"$workspace/daemon.log" 2>&1 &
daemon="$!"
trap 'kill "$daemon" 2>/dev/null || true' EXIT

for _ in $(seq 1 100); do
  [[ -S "$socket" ]] && break
  sleep 0.05
done
test -S "$socket"

"$mind" \
  --socket "$socket" \
  --actor operator \
  '(RoleClaim Operator [(Path "/git/github.com/LiGoldragon/persona-mind")] "daemon owns state")' \
  >"$workspace/claim.out"

"$mind" \
  --socket "$socket" \
  --actor operator \
  '(RoleObservation)' \
  >"$workspace/observe.out"

grep -Fq '(ClaimAcceptance Operator [(Path "/git/github.com/LiGoldragon/persona-mind")])' \
  "$workspace/claim.out"
grep -Fq '(RoleStatus Operator [(ClaimEntry (Path "/git/github.com/LiGoldragon/persona-mind") "daemon owns state")]' \
  "$workspace/observe.out"
